# Токен от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Адрес и порт backend (uvicorn)
# На сервере за nginx: HOST=127.0.0.1
# Прямой доступ снаружи: HOST=0.0.0.0
HOST=127.0.0.1
PORT=8000

# Через запятую, если фронт на другом origin
CORS_ORIGINS=http://localhost:5173

# Часовой пояс приложения (IANA-имя). Время задач и напоминаний показывается в этой зоне.
# Примеры: Europe/Moscow, Europe/London, Asia/Yekaterinburg, Asia/Novosibirsk, UTC
APP_TIMEZONE=Europe/Moscow

# Секрет подписи cookie-сессий (сменить в проде)
SESSION_SECRET=change-me-very-long-random
# Если HTTPS через nginx/caddy: 1, локально HTTP: 0
COOKIE_SECURE=0

# OAuth Google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Через сколько минут повторять напоминание, если задача не выполнена
REMINDER_REPEAT_MINUTES=10

# На сколько минут отложить задачу при нажатии «Отложить» в боте
SNOOZE_MINUTES=10

# Если dist в нестандартном месте (абсолютный путь)
# FRONTEND_DIST=/opt/task_manager/task-mannager-for-lazy/frontend/dist